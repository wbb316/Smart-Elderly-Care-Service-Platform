<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="sample-diagram" targetNamespace="http://activiti.org/bpmn" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">
  <bpmn2:process id="Process_1" name="请假工作流" isExecutable="true">
    <bpmn2:startEvent id="StartEvent_1">
      <bpmn2:outgoing>Flow_0y8s6xo</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:userTask id="Activity_0esuoda" name="护理员发起申请">
      <bpmn2:incoming>Flow_0y8s6xo</bpmn2:incoming>
      <bpmn2:incoming>Flow_056diq8</bpmn2:incoming>
      <bpmn2:incoming>Flow_159ivof</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0salhg2</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:sequenceFlow id="Flow_0y8s6xo" sourceRef="StartEvent_1" targetRef="Activity_0esuoda" />
    <bpmn2:userTask id="Activity_13rgojy" name="护理组主管审批">
      <bpmn2:incoming>Flow_0salhg2</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1exp7eh</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:sequenceFlow id="Flow_0salhg2" sourceRef="Activity_0esuoda" targetRef="Activity_13rgojy" />
    <bpmn2:exclusiveGateway id="Gateway_1aug70r">
      <bpmn2:incoming>Flow_1exp7eh</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1bjx4fe</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_056diq8</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_0s52zk2</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="Flow_1exp7eh" sourceRef="Activity_13rgojy" targetRef="Gateway_1aug70r" />
    <bpmn2:exclusiveGateway id="Gateway_172esun">
      <bpmn2:incoming>Flow_1bjx4fe</bpmn2:incoming>
      <bpmn2:outgoing>Flow_15sag3z</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_1jlb8z4</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="Flow_1bjx4fe" name="通过 approved" sourceRef="Gateway_1aug70r" targetRef="Gateway_172esun">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression">${supervisorResult == 'approved' || approveResult == 'approved'}</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:userTask id="Activity_023fe55" name="护理部部长审批">
      <bpmn2:incoming>Flow_15sag3z</bpmn2:incoming>
      <bpmn2:outgoing>Flow_088mbp9</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:sequenceFlow id="Flow_15sag3z" name="请假&#62;=3天 或 特级护理等级" sourceRef="Gateway_172esun" targetRef="Activity_023fe55">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression">${leaveDays &gt;= 3 || nursingLevel == '特级护理等级'}</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:exclusiveGateway id="Gateway_122z0r8">
      <bpmn2:incoming>Flow_088mbp9</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0p6flg3</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_159ivof</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_0zh2yav</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="Flow_088mbp9" name="&#10;" sourceRef="Activity_023fe55" targetRef="Gateway_122z0r8" />
    <bpmn2:endEvent id="Event_1qrq0gc" name="通过">
      <bpmn2:incoming>Flow_0p6flg3</bpmn2:incoming>
      <bpmn2:incoming>Flow_1jlb8z4</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_0p6flg3" name="通过 approved" sourceRef="Gateway_122z0r8" targetRef="Event_1qrq0gc">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression">${ministerResult == 'approved' || approveResult == 'approved'}</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_056diq8" name="驳回 back" sourceRef="Gateway_1aug70r" targetRef="Activity_0esuoda">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression">${supervisorResult == 'back' || approveResult == 'back'}</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_0s52zk2" name="拒绝 rejected" sourceRef="Gateway_1aug70r" targetRef="Event_0j5nqx7">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression">${supervisorResult == 'rejected' || approveResult == 'rejected'}</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_1jlb8z4" name="请假&#60;3天 且 非特级护理等级" sourceRef="Gateway_172esun" targetRef="Event_1qrq0gc">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression">${leaveDays &lt; 3 &amp;&amp; nursingLevel != '特级护理等级'}</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_159ivof" name="驳回 back" sourceRef="Gateway_122z0r8" targetRef="Activity_0esuoda">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression">${ministerResult == 'back' || approveResult == 'back'}</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_0zh2yav" name="拒绝 rejected" sourceRef="Gateway_122z0r8" targetRef="Event_0j5nqx7">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression">${ministerResult == 'rejected' || approveResult == 'rejected'}</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:endEvent id="Event_0j5nqx7" name="拒绝">
      <bpmn2:incoming>Flow_0s52zk2</bpmn2:incoming>
      <bpmn2:incoming>Flow_0zh2yav</bpmn2:incoming>
    </bpmn2:endEvent>
  </bpmn2:process>
