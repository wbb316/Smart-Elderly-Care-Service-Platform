<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcyl.code.mapper.LcRetreatHistoryMapper">

    <resultMap id="BaseResultMap" type="com.lcyl.code.domain.LcRetreatHistory">
        <id column="id" property="id"/>
        <result column="retreat_id" property="retreatId"/>
        <result column="from_node" property="fromNode"/>
        <result column="to_node" property="toNode"/>
        <result column="action" property="action"/>
        <result column="operator_id" property="operatorId"/>
        <result column="operator_name" property="operatorName"/>
        <result column="opinion" property="opinion"/>
        <result column="attachment" property="attachment"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert">
        INSERT INTO lc_retreat_history (
            retreat_id, from_node, to_node, action,
            operator_id, operator_name, opinion, attachment, create_time
        ) VALUES (
                     #{retreatId}, #{fromNode}, #{toNode}, #{action},
                     #{operatorId}, #{operatorName}, #{opinion}, #{attachment}, #{createTime}
                 )
    </insert>

    <select id="selectByRetreatId" resultMap="BaseResultMap">
        SELECT * FROM lc_retreat_history
        WHERE retreat_id = #{retreatId}
        ORDER BY create_time ASC
    </select>
</mapper>