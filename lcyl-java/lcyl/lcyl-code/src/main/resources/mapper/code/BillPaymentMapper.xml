<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcyl.code.mapper.BillPaymentMapper">
    
    <resultMap type="BillPayment" id="BillPaymentResult">
        <result property="id"    column="id"    />
        <result property="paymentNo"    column="payment_no"    />
        <result property="billId"    column="bill_id"    />
        <result property="billNo"    column="bill_no"    />
        <result property="payerName"    column="payer_name"    />
        <result property="payerPhone"    column="payer_phone"    />
        <result property="payTime"    column="pay_time"    />
        <result property="payChannel"    column="pay_channel"    />
        <result property="payMethod"    column="pay_method"    />
        <result property="wechatOrderNo"    column="wechat_order_no"    />
        <result property="payAmount"    column="pay_amount"    />
        <result property="voucherUrl"    column="voucher_url"    />
        <result property="payRemark"    column="pay_remark"    />
        <result property="operatorId"    column="operator_id"    />
        <result property="operatorName"    column="operator_name"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectBillPaymentVo">
        select id, payment_no, bill_id, bill_no, payer_name, payer_phone, pay_time, pay_channel, pay_method, wechat_order_no, pay_amount, voucher_url, pay_remark, operator_id, operator_name, create_by, create_time from lc_bill_payment
    </sql>

    <select id="selectBillPaymentList" parameterType="BillPayment" resultMap="BillPaymentResult">
        <include refid="selectBillPaymentVo"/>
        <where>  
            <if test="paymentNo != null  and paymentNo != ''"> and payment_no like concat('%', #{paymentNo}, '%')</if>
            <if test="billId != null "> and bill_id = #{billId}</if>
            <if test="billNo != null  and billNo != ''"> and bill_no like concat('%', #{billNo}, '%')</if>
            <if test="payerName != null  and payerName != ''"> and payer_name like concat('%', #{payerName}, '%')</if>
            <if test="params.beginPayTime != null and params.beginPayTime != '' and params.endPayTime != null and params.endPayTime != ''"> and pay_time between #{params.beginPayTime} and #{params.endPayTime}</if>
            <if test="payChannel != null  and payChannel != ''"> and pay_channel = #{payChannel}</if>
            <if test="payMethod != null  and payMethod != ''"> and pay_method = #{payMethod}</if>
        </where>
    </select>
    
    <select id="selectBillPaymentById" parameterType="Long" resultMap="BillPaymentResult">
        <include refid="selectBillPaymentVo"/>
        where id = #{id}
    </select>

    <insert id="insertBillPayment" parameterType="BillPayment" useGeneratedKeys="true" keyProperty="id">
        insert into lc_bill_payment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="paymentNo != null">payment_no,</if>
            <if test="billId != null">bill_id,</if>
            <if test="billNo != null">bill_no,</if>
            <if test="payerName != null">payer_name,</if>
            <if test="payerPhone != null">payer_phone,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="payChannel != null and payChannel != ''">pay_channel,</if>
            <if test="payMethod != null">pay_method,</if>
            <if test="wechatOrderNo != null">wechat_order_no,</if>
            <if test="payAmount != null">pay_amount,</if>
            <if test="voucherUrl != null">voucher_url,</if>
            <if test="payRemark != null">pay_remark,</if>
            <if test="operatorId != null">operator_id,</if>
            <if test="operatorName != null">operator_name,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="paymentNo != null">#{paymentNo},</if>
            <if test="billId != null">#{billId},</if>
            <if test="billNo != null">#{billNo},</if>
            <if test="payerName != null">#{payerName},</if>
            <if test="payerPhone != null">#{payerPhone},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="payChannel != null and payChannel != ''">#{payChannel},</if>
            <if test="payMethod != null">#{payMethod},</if>
            <if test="wechatOrderNo != null">#{wechatOrderNo},</if>
            <if test="payAmount != null">#{payAmount},</if>
            <if test="voucherUrl != null">#{voucherUrl},</if>
            <if test="payRemark != null">#{payRemark},</if>
            <if test="operatorId != null">#{operatorId},</if>
            <if test="operatorName != null">#{operatorName},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateBillPayment" parameterType="BillPayment">
        update lc_bill_payment
        <trim prefix="SET" suffixOverrides=",">
            <if test="paymentNo != null">payment_no = #{paymentNo},</if>
            <if test="billId != null">bill_id = #{billId},</if>
            <if test="billNo != null">bill_no = #{billNo},</if>
            <if test="payerName != null">payer_name = #{payerName},</if>
            <if test="payerPhone != null">payer_phone = #{payerPhone},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="payChannel != null and payChannel != ''">pay_channel = #{payChannel},</if>
            <if test="payMethod != null">pay_method = #{payMethod},</if>
            <if test="wechatOrderNo != null">wechat_order_no = #{wechatOrderNo},</if>
            <if test="payAmount != null">pay_amount = #{payAmount},</if>
            <if test="voucherUrl != null">voucher_url = #{voucherUrl},</if>
            <if test="payRemark != null">pay_remark = #{payRemark},</if>
            <if test="operatorId != null">operator_id = #{operatorId},</if>
            <if test="operatorName != null">operator_name = #{operatorName},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteBillPaymentById" parameterType="Long">
        delete from lc_bill_payment where id = #{id}
    </delete>

    <delete id="deleteBillPaymentByIds" parameterType="String">
        delete from lc_bill_payment where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>