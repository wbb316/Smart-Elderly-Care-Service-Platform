<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcyl.code.mapper.LcCheckinHealthEvaluateMapper">
    
    <resultMap type="LcCheckinHealthEvaluate" id="LcCheckinHealthEvaluateResult">
        <result property="id"    column="id"    />
        <result property="applyId"    column="apply_id"    />
        <result property="height"    column="height"    />
        <result property="weight"    column="weight"    />
        <result property="bloodPressure"    column="blood_pressure"    />
        <result property="bloodSugar"    column="blood_sugar"    />
        <result property="chronicDisease"    column="chronic_disease"    />
        <result property="allergy"    column="allergy"    />
        <result property="evaluateDoctor"    column="evaluate_doctor"    />
        <result property="evaluateTime"    column="evaluate_time"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
