<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcyl.code.mapper.NursingItemMapper">
    
    <resultMap type="NursingItem" id="NursingItemResult">
        <result property="id"    column="id"    />
        <result property="itemName"    column="item_name"    />
        <result property="price"    column="price"    />
        <result property="unit"    column="unit"    />
        <result property="sort"    column="sort"    />
        <result property="imageUrl"    column="image_url"    />
        <result property="itemDesc"    column="item_desc"    />
        <result property="status"    column="status"    />
        <result property="creatorId"    column="creator_id"    />
        <result property="creatorName"    column="creator_name"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectNursingItemVo">
        select id, item_name, price, unit, sort, image_url, item_desc, status, creator_id, creator_name, create_time, update_time from lc_nursing_item
    </sql>

    <select id="selectNursingItemList" parameterType="NursingItem" resultMap="NursingItemResult">
        <include refid="selectNursingItemVo"/>
        <where>  
            <if test="itemName != null  and itemName != ''"> and item_name like concat('%', #{itemName}, '%')</if>
            <if test="price != null "> and price = #{price}</if>
            <if test="unit != null  and unit != ''"> and unit = #{unit}</if>
            <if test="sort != null "> and sort = #{sort}</if>
            <if test="imageUrl != null  and imageUrl != ''"> and image_url = #{imageUrl}</if>
            <if test="itemDesc != null  and itemDesc != ''"> and item_desc = #{itemDesc}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="creatorId != null "> and creator_id = #{creatorId}</if>
            <if test="creatorName != null  and creatorName != ''"> and creator_name like concat('%', #{creatorName}, '%')</if>
        </where>
    </select>
    
    <select id="selectNursingItemById" parameterType="Long" resultMap="NursingItemResult">
        <include refid="selectNursingItemVo"/>
        where id = #{id}
    </select>
    <select id="countItemName" resultType="java.lang.Integer">
        SELECT COUNT(1) FROM lc_nursing_item
        WHERE item_name = #{itemName}
    </select>

    <insert id="insertNursingItem" parameterType="NursingItem" useGeneratedKeys="true" keyProperty="id">
        insert into lc_nursing_item
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="itemName != null and itemName != ''">item_name,</if>
            <if test="price != null">price,</if>
            <if test="unit != null and unit != ''">unit,</if>
            <if test="sort != null">sort,</if>
            <if test="imageUrl != null">image_url,</if>
            <if test="itemDesc != null">item_desc,</if>
            <if test="status != null">status,</if>
            <if test="creatorId != null">creator_id,</if>
            <if test="creatorName != null and creatorName != ''">creator_name,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="itemName != null and itemName != ''">#{itemName},</if>
            <if test="price != null">#{price},</if>
            <if test="unit != null and unit != ''">#{unit},</if>
            <if test="sort != null">#{sort},</if>
            <if test="imageUrl != null">#{imageUrl},</if>
            <if test="itemDesc != null">#{itemDesc},</if>
            <if test="status != null">#{status},</if>
            <if test="creatorId != null">#{creatorId},</if>
            <if test="creatorName != null and creatorName != ''">#{creatorName},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateNursingItem" parameterType="NursingItem">
        update lc_nursing_item
        <trim prefix="SET" suffixOverrides=",">
            <if test="itemName != null and itemName != ''">item_name = #{itemName},</if>
            <if test="price != null">price = #{price},</if>
            <if test="unit != null and unit != ''">unit = #{unit},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="itemDesc != null">item_desc = #{itemDesc},</if>
            <if test="status != null">status = #{status},</if>
            <if test="creatorId != null">creator_id = #{creatorId},</if>
            <if test="creatorName != null and creatorName != ''">creator_name = #{creatorName},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteNursingItemById" parameterType="Long">
        delete from lc_nursing_item where id = #{id}
    </delete>

    <delete id="deleteNursingItemByIds" parameterType="String">
        delete from lc_nursing_item where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>