<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcyl.code.mapper.ElderRegistrationMapper">

    <resultMap type="com.lcyl.code.domain.ElderRegistration" id="ElderRegistrationResult">
        <id property="id" column="id"/>
        <result property="memberId" column="member_id"/>
        <result property="name" column="name"/>
        <result property="idCardNo" column="id_card_no"/>
        <result property="age" column="age"/>
        <result property="sex" column="sex"/>
        <result property="phone" column="phone"/>
        <result property="image" column="image"/>
        <result property="remark" column="remark"/>
        <result property="relation" column="relation"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectElderRegistrationVo">
        select id, member_id, name, id_card_no, age, sex, phone, image, remark, relation, status, create_time, update_time
        from elder_registration
    </sql>

    <select id="selectElderRegistrationList" parameterType="com.lcyl.code.domain.ElderRegistration" resultMap="ElderRegistrationResult">
        <include refid="selectElderRegistrationVo"/>
        <where>
            <if test="name != null and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectElderRegistrationById" parameterType="Long" resultMap="ElderRegistrationResult">
        <include refid="selectElderRegistrationVo"/>
        where id = #{id}
    </select>

    <insert id="insertElderRegistration" parameterType="com.lcyl.code.domain.ElderRegistration" useGeneratedKeys="true" keyProperty="id">
        insert into elder_registration
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="memberId != null">member_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="idCardNo != null">id_card_no,</if>
            <if test="age != null">age,</if>
            <if test="sex != null">sex,</if>
            <if test="phone != null">phone,</if>
            <if test="image != null">image,</if>
            <if test="remark != null">remark,</if>
            <if test="relation != null">relation,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="memberId != null">#{memberId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="idCardNo != null">#{idCardNo},</if>
            <if test="age != null">#{age},</if>
            <if test="sex != null">#{sex},</if>
            <if test="phone != null">#{phone},</if>
            <if test="image != null">#{image},</if>
            <if test="remark != null">#{remark},</if>
            <if test="relation != null">#{relation},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateElderRegistration" parameterType="com.lcyl.code.domain.ElderRegistration">
        update elder_registration
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="idCardNo != null">id_card_no = #{idCardNo},</if>
            <if test="age != null">age = #{age},</if>
            <if test="sex != null">sex = #{sex},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="image != null">image = #{image},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="relation != null">relation = #{relation},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

</mapper>
