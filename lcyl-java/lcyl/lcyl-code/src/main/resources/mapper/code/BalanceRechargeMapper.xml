<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcyl.code.mapper.BalanceRechargeMapper">
    
    <resultMap type="BalanceRecharge" id="BalanceRechargeResult">
        <result property="id"    column="id"    />
        <result property="rechargeNo"    column="recharge_no"    />
        <result property="elderId"    column="elder_id"    />
        <result property="elderName"    column="elder_name"    />
        <result property="bedNo"    column="bed_no"    />
        <result property="rechargeMethod"    column="recharge_method"    />
        <result property="rechargeAmount"    column="recharge_amount"    />
        <result property="voucherUrl"    column="voucher_url"    />
        <result property="rechargeRemark"    column="recharge_remark"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectBalanceRechargeVo">
        select id, recharge_no, elder_id, elder_name, bed_no, recharge_method, recharge_amount, voucher_url, recharge_remark, status, create_by, create_time, update_by, update_time, del_flag, remark from lc_balance_recharge
    </sql>

    <select id="selectBalanceRechargeList" parameterType="BalanceRecharge" resultMap="BalanceRechargeResult">
        <include refid="selectBalanceRechargeVo"/>
        <where>  
            <if test="rechargeNo != null  and rechargeNo != ''"> and recharge_no like concat('%', #{rechargeNo}, '%')</if>
            <if test="elderId != null "> and elder_id = #{elderId}</if>
            <if test="elderName != null  and elderName != ''"> and elder_name like concat('%', #{elderName}, '%')</if>
            <if test="bedNo != null  and bedNo != ''"> and bed_no like concat('%', #{bedNo}, '%')</if>
            <if test="rechargeMethod != null  and rechargeMethod != ''"> and recharge_method = #{rechargeMethod}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and create_time between #{params.beginCreateTime} and #{params.endCreateTime}</if>
        </where>
    </select>
    
    <select id="selectBalanceRechargeById" parameterType="Long" resultMap="BalanceRechargeResult">
        <include refid="selectBalanceRechargeVo"/>
        where id = #{id}
    </select>

    <select id="selectRechargeElderOptions" resultType="com.lcyl.code.domain.vo.RechargeElderOptionVO">
        select
            e.id as elderId,
            e.name as elderName,
            e.bed_number as bedNo
        from elder e
        order by e.id asc
    </select>

    <insert id="insertBalanceRecharge" parameterType="BalanceRecharge" useGeneratedKeys="true" keyProperty="id">
        insert into lc_balance_recharge
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="rechargeNo != null">recharge_no,</if>
            <if test="elderId != null">elder_id,</if>
            <if test="elderName != null">elder_name,</if>
            <if test="bedNo != null">bed_no,</if>
            <if test="rechargeMethod != null">recharge_method,</if>
            <if test="rechargeAmount != null">recharge_amount,</if>
            <if test="voucherUrl != null">voucher_url,</if>
            <if test="rechargeRemark != null">recharge_remark,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="rechargeNo != null">#{rechargeNo},</if>
            <if test="elderId != null">#{elderId},</if>
            <if test="elderName != null">#{elderName},</if>
            <if test="bedNo != null">#{bedNo},</if>
            <if test="rechargeMethod != null">#{rechargeMethod},</if>
            <if test="rechargeAmount != null">#{rechargeAmount},</if>
            <if test="voucherUrl != null">#{voucherUrl},</if>
            <if test="rechargeRemark != null">#{rechargeRemark},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateBalanceRecharge" parameterType="BalanceRecharge">
        update lc_balance_recharge
        <trim prefix="SET" suffixOverrides=",">
            <if test="rechargeNo != null">recharge_no = #{rechargeNo},</if>
            <if test="elderId != null">elder_id = #{elderId},</if>
            <if test="elderName != null">elder_name = #{elderName},</if>
            <if test="bedNo != null">bed_no = #{bedNo},</if>
            <if test="rechargeMethod != null">recharge_method = #{rechargeMethod},</if>
            <if test="rechargeAmount != null">recharge_amount = #{rechargeAmount},</if>
            <if test="voucherUrl != null">voucher_url = #{voucherUrl},</if>
            <if test="rechargeRemark != null">recharge_remark = #{rechargeRemark},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteBalanceRechargeById" parameterType="Long">
        delete from lc_balance_recharge where id = #{id}
    </delete>

    <delete id="deleteBalanceRechargeByIds" parameterType="String">
        delete from lc_balance_recharge where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <insert id="insertRechargeRecord" parameterType="com.lcyl.code.domain.dto.BalanceRechargeDTO">
        insert into lc_balance_recharge
        (
            recharge_no,
            elder_id,
            elder_name,
            bed_no,
            recharge_method,
            recharge_amount,
            voucher_url,
            recharge_remark,
            status,
            create_by,
            create_time,
            update_by,
            update_time,
            del_flag,
            remark
        )
        values
        (
            #{rechargeNo},
            #{elderId},
            #{elderName},
            #{bedNo},
            #{rechargeMethod},
            #{rechargeAmount},
            #{voucherUrl},
            #{rechargeRemark},
            #{status},
            #{createBy},
            #{createTime},
            #{updateBy},
            #{updateTime},
            #{delFlag},
            #{remark}
        )
    </insert>

    <select id="countBalanceByElderId" parameterType="Long" resultType="int">
        select count(1)
        from balance
        where elder_id = #{elderId}
    </select>

    <update id="updateBalancePrepaid">
        update balance
        set prepaid_balance = ifnull(prepaid_balance, 0) + #{rechargeAmount},
            elder_name = #{elderName},
            bed_no = #{bedNo},
            update_by = #{updateBy},
            update_time = now()
        where elder_id = #{elderId}
    </update>

    <insert id="insertBalanceAccountByRecharge">
        insert into balance
        (
            prepaid_balance,
            deposit_amount,
            arrears_amount,
            payment_deadline,
            status,
            elder_id,
            elder_name,
            bed_no,
            create_time,
            update_time,
            create_by,
            update_by,
            remark,
            del_flag
        )
        values
        (
            #{dto.rechargeAmount},
            0.00,
            0.00,
            null,
            0,
            #{dto.elderId},
            #{dto.elderName},
            #{dto.bedNo},
            #{dto.createTime},
            #{dto.updateTime},
            #{userId},
            #{userId},
            '充值初始化账户',
            '0'
        )
    </insert>

    <select id="selectElderIdByName" parameterType="String" resultType="java.lang.Long">
        select id
        from elder
        where name = #{elderName}
        limit 1
    </select>
</mapper>
