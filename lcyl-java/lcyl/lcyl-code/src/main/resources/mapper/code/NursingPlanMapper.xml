<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcyl.code.mapper.NursingPlanMapper">
    
    <resultMap type="NursingPlan" id="NursingPlanResult">
        <result property="id"    column="id"    />
        <result property="planName"    column="plan_name"    />
        <result property="status"    column="status"    />
        <result property="creatorId"    column="creator_id"    />
        <result property="creatorName"    column="creator_name"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <resultMap id="NursingPlanNursingPlanItemResult" type="NursingPlan" extends="NursingPlanResult">
        <collection property="nursingPlanItemList" ofType="NursingPlanItem" column="id" select="selectNursingPlanItemList" />
    </resultMap>

    <resultMap type="NursingPlanItem" id="NursingPlanItemResult">
        <result property="id"    column="id"    />
        <result property="planId"    column="plan_id"    />
        <result property="itemId"    column="item_id"    />
        <result property="expectedTime"    column="expected_time"    />
        <result property="executeCycle"    column="execute_cycle"    />
        <result property="executeTimes"    column="execute_times"    />
    </resultMap>

    <sql id="selectNursingPlanVo">
        select id, plan_name, status, creator_id, creator_name, create_time, update_time from lc_nursing_plan
    </sql>

    <select id="selectNursingPlanList" parameterType="NursingPlan" resultMap="NursingPlanResult">
        SELECT
        np.id,
        np.plan_name,
        np.status,
        np.creator_id,
        np.creator_name,
        np.create_time,
        np.update_time,
        -- 新增：判断是否被护理等级绑定
        CASE WHEN COUNT(nl.id) > 0 THEN 1 ELSE 0 END AS isBound
        FROM lc_nursing_plan np
        LEFT JOIN lc_nursing_level nl ON np.id = nl.plan_id
        <where>
            <if test="planName != null and planName != ''">
                AND np.plan_name LIKE CONCAT('%', #{planName}, '%')
            </if>
            <if test="status != null">
                AND np.status = #{status}
            </if>
        </where>
        GROUP BY np.id
    </select>
    
    <select id="selectNursingPlanById" parameterType="Long" resultMap="NursingPlanNursingPlanItemResult">
        select id, plan_name, status, creator_id, creator_name, create_time, update_time
        from lc_nursing_plan
        where id = #{id}
    </select>

    <select id="selectNursingPlanItemList" resultMap="NursingPlanItemResult">
        select id, plan_id, item_id, expected_time, execute_cycle, execute_times
        from lc_nursing_plan_item
        where plan_id = #{plan_id}
    </select>
    <select id="countPlanName" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM lc_nursing_plan
        WHERE plan_name = #{planName}
    </select>

    <insert id="insertNursingPlan" parameterType="NursingPlan" useGeneratedKeys="true" keyProperty="id">
        insert into lc_nursing_plan
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="planName != null and planName != ''">plan_name,</if>
            <if test="status != null">status,</if>
            <if test="creatorId != null">creator_id,</if>
            <if test="creatorName != null and creatorName != ''">creator_name,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="planName != null and planName != ''">#{planName},</if>
            <if test="status != null">#{status},</if>
            <if test="creatorId != null">#{creatorId},</if>
            <if test="creatorName != null and creatorName != ''">#{creatorName},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateNursingPlan" parameterType="NursingPlan">
        update lc_nursing_plan
        <trim prefix="SET" suffixOverrides=",">
            <if test="planName != null and planName != ''">plan_name = #{planName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="creatorId != null">creator_id = #{creatorId},</if>
            <if test="creatorName != null and creatorName != ''">creator_name = #{creatorName},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteNursingPlanById" parameterType="Long">
        delete from lc_nursing_plan where id = #{id}
    </delete>

    <delete id="deleteNursingPlanByIds" parameterType="String">
        delete from lc_nursing_plan where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <delete id="deleteNursingPlanItemByPlanIds" parameterType="String">
        delete from lc_nursing_plan_item where plan_id in 
        <foreach item="planId" collection="array" open="(" separator="," close=")">
            #{planId}
        </foreach>
    </delete>

    <delete id="deleteNursingPlanItemByPlanId" parameterType="Long">
        delete from lc_nursing_plan_item where plan_id = #{planId}
    </delete>

    <insert id="batchNursingPlanItem">
        insert into lc_nursing_plan_item( id, plan_id, item_id, expected_time, execute_cycle, execute_times) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.planId}, #{item.itemId}, #{item.expectedTime}, #{item.executeCycle}, #{item.executeTimes})
        </foreach>
    </insert>
</mapper>