    <sql id="selectLcServiceOrderRefundVo">
        select id, refund_no, order_id, order_no, refund_amount, refund_status, applicant_id, applicant_name, applicant_type, apply_time, refund_time, refund_reason, refund_channel, refund_method, fail_code, fail_reason, remark, del_flag, create_by, create_time, update_by, update_time from lc_service_order_refund
    </sql>

    <select id="selectLcServiceOrderRefundList" parameterType="LcServiceOrderRefund" resultMap="LcServiceOrderRefundResult">
        <include refid="selectLcServiceOrderRefundVo"/>
        <where>
            del_flag = '0'
            <if test="refundNo != null  and refundNo != ''"> and refund_no = #{refundNo}</if>
            <if test="orderId != null "> and order_id = #{orderId}</if>
            <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="refundAmount != null "> and refund_amount = #{refundAmount}</if>
            <if test="refundStatus != null  and refundStatus != ''"> and refund_status = #{refundStatus}</if>
            <if test="applicantId != null "> and applicant_id = #{applicantId}</if>
            <if test="applicantName != null  and applicantName != ''"> and applicant_name like concat('%', #{applicantName}, '%')</if>
            <if test="applicantType != null  and applicantType != ''"> and applicant_type = #{applicantType}</if>
            <if test="applyTime != null "> and apply_time = #{applyTime}</if>
            <if test="refundTime != null "> and refund_time = #{refundTime}</if>
            <if test="refundReason != null  and refundReason != ''"> and refund_reason = #{refundReason}</if>
            <if test="refundChannel != null  and refundChannel != ''"> and refund_channel = #{refundChannel}</if>
            <if test="refundMethod != null  and refundMethod != ''"> and refund_method = #{refundMethod}</if>
            <if test="failCode != null  and failCode != ''"> and fail_code = #{failCode}</if>
            <if test="failReason != null  and failReason != ''"> and fail_reason = #{failReason}</if>
        </where>
    </select>
    
    <select id="selectLcServiceOrderRefundById" parameterType="Long" resultMap="LcServiceOrderRefundResult">
        <include refid="selectLcServiceOrderRefundVo"/>
        where id = #{id} and del_flag = '0'
    </select>

    <insert id="insertLcServiceOrderRefund" parameterType="LcServiceOrderRefund" useGeneratedKeys="true" keyProperty="id">
        insert into lc_service_order_refund
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="refundNo != null and refundNo != ''">refund_no,</if>
            <if test="orderId != null">order_id,</if>
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="refundAmount != null">refund_amount,</if>
            <if test="refundStatus != null and refundStatus != ''">refund_status,</if>
            <if test="applicantId != null">applicant_id,</if>
            <if test="applicantName != null and applicantName != ''">applicant_name,</if>
            <if test="applicantType != null and applicantType != ''">applicant_type,</if>
            <if test="applyTime != null">apply_time,</if>
            <if test="refundTime != null">refund_time,</if>
            <if test="refundReason != null">refund_reason,</if>
            <if test="refundChannel != null">refund_channel,</if>
            <if test="refundMethod != null">refund_method,</if>
            <if test="failCode != null">fail_code,</if>
            <if test="failReason != null">fail_reason,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="refundNo != null and refundNo != ''">#{refundNo},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="refundAmount != null">#{refundAmount},</if>
            <if test="refundStatus != null and refundStatus != ''">#{refundStatus},</if>
            <if test="applicantId != null">#{applicantId},</if>
            <if test="applicantName != null and applicantName != ''">#{applicantName},</if>
            <if test="applicantType != null and applicantType != ''">#{applicantType},</if>
            <if test="applyTime != null">#{applyTime},</if>
            <if test="refundTime != null">#{refundTime},</if>
            <if test="refundReason != null">#{refundReason},</if>
            <if test="refundChannel != null">#{refundChannel},</if>
            <if test="refundMethod != null">#{refundMethod},</if>
            <if test="failCode != null">#{failCode},</if>
            <if test="failReason != null">#{failReason},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateLcServiceOrderRefund" parameterType="LcServiceOrderRefund">
        update lc_service_order_refund
        <trim prefix="SET" suffixOverrides=",">
            <if test="refundNo != null and refundNo != ''">refund_no = #{refundNo},</if>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="refundAmount != null">refund_amount = #{refundAmount},</if>
            <if test="refundStatus != null and refundStatus != ''">refund_status = #{refundStatus},</if>
            <if test="applicantId != null">applicant_id = #{applicantId},</if>
            <if test="applicantName != null and applicantName != ''">applicant_name = #{applicantName},</if>
            <if test="applicantType != null and applicantType != ''">applicant_type = #{applicantType},</if>
            <if test="applyTime != null">apply_time = #{applyTime},</if>
            <if test="refundTime != null">refund_time = #{refundTime},</if>
            <if test="refundReason != null">refund_reason = #{refundReason},</if>
            <if test="refundChannel != null">refund_channel = #{refundChannel},</if>
            <if test="refundMethod != null">refund_method = #{refundMethod},</if>
            <if test="failCode != null">fail_code = #{failCode},</if>
            <if test="failReason != null">fail_reason = #{failReason},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
