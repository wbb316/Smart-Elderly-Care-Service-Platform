    <update id="deleteLcServiceOrderRefundById" parameterType="Long">
        update lc_service_order_refund set del_flag = '2', update_time = sysdate() where id = #{id}
    </update>

    <update id="deleteLcServiceOrderRefundByIds" parameterType="String">
        update lc_service_order_refund set del_flag = '2', update_time = sysdate() where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <update id="updateOrderStatusByOrderNo">
        update lc_service_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderStatus != null and orderStatus != ''">order_status = #{orderStatus},</if>
            trade_status = #{tradeStatus},
            update_time = sysdate(),
        </trim>
        where order_no = #{orderNo}
    </update>

    <update id="updateBillTradeStatusByOrderNo">
        update lc_bill
        set trade_status = #{tradeStatus}, update_time = sysdate()
        where del_flag = '0' and order_no = #{orderNo}
    </update>
