/* 容器 */
.bind-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 表单卡片 */
.form-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 40rpx;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}
.form-item:last-child {
  border-bottom: none;
}

.form-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.form-label {
  font-size: 32rpx;
  color: #333;
}

/* 步骤徽章（红色圆形数字） */
.step-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f26b6b;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #333;
  margin: 0 20rpx;
}

.required-tip {
  font-size: 28rpx;
  color: #999;
}

/* 绑定按钮 */
.bind-btn {
  background-color: #fff;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  gap: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.btn-badge {
  width: 70rpx;
  height: 70rpx;
  font-size: 32rpx;
}

.btn-text {
  font-size: 36rpx;
  color: #007aff;
  font-weight: 500;
}