.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 30rpx;
}
.header {
  margin-bottom: 30rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 30rpx;
}
.card-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.coming-soon-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}
.coming-soon-text {
  font-size: 28rpx;
  color: #999;
}
