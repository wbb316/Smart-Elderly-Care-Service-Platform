page {
  background: #f5f7fa;
}
.page {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 导航 */
.custom-nav {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.nav-left {
  position: absolute;
  left: 20rpx;
  padding: 10rpx;
}
.back-icon {
  font-size: 48rpx;
  color: #222;
}
.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #111;
}
.nav-right {
  position: absolute;
  right: 20rpx;
  width: 60rpx;
}

/* 内容 */
.content {
  padding: 24rpx;
}
.loading {
  text-align: center;
  padding: 50rpx 0;
  color: #666;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}
.empty-img {
  width: 240rpx;
  height: 240rpx;
  opacity: 0.9;
  margin-bottom: 30rpx;
}
.empty-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.04);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.contract-no {
  font-size: 26rpx;
  color: #888;
}
.status-tag {
  padding: 6rpx 18rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
}
.status-pending {
  color: #e67c45;
  background: #fff1e8;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
}
.status-active {
  color: #2f7b44;
  background: #e6f4e8;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
}
/* 已过期 - 红色 ✅ */
.status-expired {
  background: #f56c6c;
  color: #fff;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
}
/* 未生效 —— 灰色 */
.status-pending {
  background: #909399;
  color: #fff;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
}

/* 主体 */
.card-body {
  display: flex;
  margin-bottom: 20rpx;
}
.cover {
  width: 180rpx;
  height: 130rpx;
  border-radius: 16rpx;
  background: #f2f2f2;
  margin-right: 20rpx;
}
.info {
  flex: 1;
}
.name {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  color: #222;
}
.row {
  display: flex;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}
.row text:first-child {
  width: 110rpx;
  color: #999;
}

/* 按钮 */
.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
.btn {
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
}
.btn-view {
  border: 1rpx solid #ddd;
  color: #444;
}
.btn-download {
  background: #fff2ec;
  color: #ff6b35;
  border: 1rpx solid #ffd4c2;
}

/* 弹窗（完全匹配截图样式） */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}
.popup {
  width: 680rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx 50rpx;
  text-align: center;
}
.pdf-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  background: #ff6b35;
  border-radius: 12rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: #222;
}
.tip {
  font-size: 30rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 40rpx;
}
.copy-btn {
  background: #ff7a45;
  color: #fff;
  border-radius: 50rpx;
  height: 90rpx;
  margin-left: 80px;
  width: 180px;
  line-height: 90rpx;
  font-size: 32rpx;
  font-weight: 500;
}

/* 复制成功提示（完全匹配截图样式） */
.toast {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.75);
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  z-index: 100;
}