page {
  background: #f6f7fb;
}

.page {
  min-height: 100vh;
  background: #f6f7fb;
}

/* 自定义导航栏 */
.custom-nav {
  background: linear-gradient(180deg, #ff9d73 0%, #ff7a45 100%);
  box-sizing: border-box;
}

.nav-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-left {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 400;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.nav-right-placeholder {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
}

/* 页面主体 */
.page-body {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.label {
  font-size: 30rpx;
  color: #222222;
  font-weight: 500;
}

.input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #333333;
  margin-left: 30rpx;
}

/* 头像 */
.avatar-item {
  min-height: 140rpx;
}

.avatar-right {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f2f2f2;
}

/* 性别 */
.picker-item {
  cursor: pointer;
}

.picker-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.picker-text {
  font-size: 30rpx;
  padding-bottom: 30rpx;
  color: #bbbbbb;
  line-height: 1;
  display: flex;
  align-items: center;
}

.picker-text.active {
  color: #333333;
}

.arrow {
  margin-left: 12rpx;
  font-size: 32rpx;
  color: #bfbfbf;
  line-height: 1;
  display: flex;
  align-items: center;
}

/* 按钮 */
.btn-wrapper {
  margin-top: 80rpx;
  padding: 0 12rpx;
  display: flex;
  justify-content: center;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(180deg, #ff9d73 0%, #ff7a45 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;

  display: flex;
  align-items: center;
  justify-content: center;

  padding: 0;
  line-height: normal;
}

.save-btn::after {
  border: none;
}