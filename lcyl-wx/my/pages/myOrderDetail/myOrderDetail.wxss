page {
  background: #f6f6f6;
}

.page {
  min-height: 100vh;
  background: #f6f6f6;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.custom-nav {
  background: #ffffff;
  box-sizing: border-box;
}

.nav-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-left {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 52rpx;
  color: #222222;
  line-height: 1;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #222222;
}

.nav-right-placeholder {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}

.loading-wrap {
  padding: 200rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 30rpx;
  color: #999999;
}

.content {
  padding: 0 24rpx 24rpx;
  box-sizing: border-box;
}

.state-banner {
  background: #ff9f1a;
  color: #ffffff;
  padding: 30rpx 26rpx;
  margin-bottom: 24rpx;
}

.state-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.state-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.section-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.goods-main {
  display: flex;
  align-items: flex-start;
}

.goods-image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 10rpx;
  background: #f2f2f2;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.goods-name {
  font-size: 36rpx;
  color: #333333;
  line-height: 1.5;
}

.goods-price {
  margin-top: 10rpx;
  font-size: 34rpx;
  color: #ff9f1a;
  font-weight: 700;
}

.goods-total {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.goods-total-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
}

.goods-total-value {
  font-size: 38rpx;
  color: #ff9f1a;
  font-weight: 700;
}

.cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  gap: 24rpx;
}

.cell-top {
  align-items: flex-start;
}

.cell-label {
  width: 170rpx;
  flex-shrink: 0;
  font-size: 30rpx;
  color: #222222;
  font-weight: 600;
  line-height: 1.6;
}

.cell-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #222222;
  line-height: 1.7;
  word-break: break-all;
}

.multiline {
  text-align: left;
}

.image-box {
  display: flex;
  justify-content: flex-end;
}

.record-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f2f2f2;
}

.placeholder-text {
  color: #999999;
  font-size: 26rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 20rpx;
  box-sizing: border-box;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.bottom-btn {
  margin: 0;
  min-width: 210rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.bottom-btn::after {
  border: none;
}

.bottom-btn-default {
  background: #ffffff;
  color: #333333;
  border: 1rpx solid #cfcfcf;
}

.bottom-btn-primary {
  background: #1d25d8;
  color: #ffffff;
}
