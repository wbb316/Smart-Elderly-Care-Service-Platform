page {
  background: #f7f7f7;
}

.page {
  min-height: 100vh;
  background: #f7f7f7;
}

/* 自定义导航栏 */
.custom-nav {
  background: #ffffff;
  box-sizing: border-box;
}

.nav-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-left {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 52rpx;
  color: #333333;
  font-weight: 400;
  line-height: 1;
}

.nav-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #222222;
  line-height: 1;
}

.nav-right-placeholder {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* tabs */
.tabs {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 0 20rpx;
  height: 88rpx;
  box-sizing: border-box;
  border-top: 1rpx solid #f5f5f5;
}

.tab-item {
  position: relative;
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: #333333;
  line-height: 88rpx;
}

.tab-item.active {
  color: #ff6b3d;
  font-weight: 600;
}

.tab-item.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 12rpx;
  transform: translateX(-50%);
  width: 44rpx;
  height: 6rpx;
  background: #ff6b3d;
  border-radius: 6rpx;
}

/* 列表 */
.order-list {
  padding: 18rpx 20rpx 30rpx;
  box-sizing: border-box;
}

.order-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 26rpx 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.order-main {
  display: flex;
  align-items: flex-start;
}

.service-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 18rpx;
  background: #f2f2f2;
  flex-shrink: 0;
}

.order-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.service-name {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #222222;
  line-height: 1.4;
  margin-right: 16rpx;
}

.status-text {
  font-size: 30rpx;
  font-weight: 500;
  white-space: nowrap;
  line-height: 1.4;
}

.status-pendingPay {
  color: #ff6b3d;
}

.status-pendingService {
  color: #ff6b3d;
}

.status-executed {
  color: #444444;
}

.status-completed {
  color: #444444;
}

.status-refundProcessing {
  color: #ff9f43;
}

.status-refunded {
  color: #67c23a;
}

.status-refundFailed {
  color: #f56c6c;
}

.status-closed {
  color: #999999;
}

.info-line {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #999999;
  line-height: 1.5;
}

.price-line {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
}

.price-label {
  font-size: 30rpx;
  color: #222222;
  font-weight: 600;
  margin-right: 8rpx;
}

.price-symbol {
  font-size: 30rpx;
  color: #ff6b3d;
  margin-right: 2rpx;
}

.price-value {
  font-size: 46rpx;
  font-weight: 700;
  color: #ff6b3d;
  line-height: 1;
}

.divider {
  height: 1rpx;
  background: #f2f2f2;
  margin: 22rpx 0 22rpx;
}

/* 按钮区域 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.action-btn {
  margin: 0;
  padding: 0 30rpx;
  min-width: 150rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 500;
  text-align: center;
  background: #ffffff;
  box-sizing: border-box;
}

/* 按钮间距 */
.action-btn + .action-btn {
  margin-left: 20rpx;
}

/* 去掉微信 button 默认边框 */
.action-btn::after {
  border: none;
}

.action-btn-default {
  color: #333333;
  border: 2rpx solid #d8d8d8;
  background: #ffffff;
}

.action-btn-primary {
  color: #ff6b3d;
  border: 2rpx solid #ff6b3d;
  background: #ffffff;
}

/* 空状态 */
.empty {
  padding: 200rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
}
