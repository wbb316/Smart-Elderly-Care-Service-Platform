page {
  background: #f5f5f7;
}

.page {
  min-height: 100vh;
  background: #f5f5f7;
}

/* 自定义导航栏 */
.custom-nav {
  background: #ffffff;
  box-sizing: border-box;
}

.nav-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-left {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 52rpx;
  color: #222222;
  line-height: 1;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #222222;
}

.nav-right-placeholder {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 顶部状态tab */
.status-tabs {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.status-tab-item {
  position: relative;
  margin-right: 52rpx;
  padding: 24rpx 0;
  font-size: 34rpx;
  color: #333333;
  font-weight: 500;
}

.status-tab-item.active {
  color: #ff6b3d;
  font-weight: 700;
}

.status-tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  transform: translateX(-50%);
  width: 52rpx;
  height: 6rpx;
  background: #ff6b3d;
  border-radius: 6rpx;
}

/* 老人tab */
.elder-tabs-wrapper {
  background: #ececef;
  white-space: nowrap;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
}

.elder-tabs {
  display: inline-flex;
  align-items: center;
}

.elder-tab-item {
  flex-shrink: 0;
  min-width: 96rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 28rpx;
  margin-right: 20rpx;
  text-align: center;
  background: #ffffff;
  border: 2rpx solid #d9d9d9;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #555555;
  box-sizing: border-box;
}

.elder-tab-item.active {
  background: #ff6b3d;
  border-color: #ff6b3d;
  color: #ffffff;
}

/* 列表 */
.bill-list {
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.bill-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.bill-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-no {
  font-size: 30rpx;
  color: #8a8a8a;
}

.status-text {
  font-size: 34rpx;
  font-weight: 600;
}

.status-text.pending {
  color: #ff6b3d;
}

.status-text.paid {
  color: #67c23a;
}

.status-text.closed {
  color: #999999;
}

.status-text.refunded {
  color: #909399;
}

.bill-main {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.bill-main-left {
  flex: 1;
  min-width: 0;
}

.bill-main-right {
  width: 210rpx;
  text-align: right;
  flex-shrink: 0;
}

.bill-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 18rpx;
}

.bill-info {
  font-size: 31rpx;
  color: #8c8c8c;
  line-height: 1.9;
}

.bill-amount {
  font-size: 44rpx;
  color: #ff6b3d;
  font-weight: 700;
  margin-top: 8rpx;
  margin-bottom: 22rpx;
}

.bill-month {
  font-size: 30rpx;
  color: #8c8c8c;
  line-height: 1.6;
}

.bill-divider {
  height: 1rpx;
  background: #eeeeee;
  margin: 24rpx 0;
}

.bill-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.btn {
  min-width: 140rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 32rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.detail-btn {
  color: #444444;
  border: 2rpx solid #dddddd;
  background: #ffffff;
  margin-right: 20rpx;
}

.pay-btn {
  color: #ff6b3d;
  border: 2rpx solid #ff6b3d;
  background: #ffffff;
}

/* 空状态 */
.empty-wrap {
  padding: 160rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
}
