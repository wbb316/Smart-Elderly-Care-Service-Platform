.container {
  background: #F7F6FB;
  min-height: 100vh;
  padding: 20rpx;
}

.empty {
  text-align: center;
  padding-top: 200rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F4F4F4;
}
.booking-no {
  font-size: 24rpx;
  color: #999;
}
.status {
  font-size: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}
.status-pending {
  background: #FFF3E0;
  color: #FF9800;
}
.status-paid {
  background: #E8F5E9;
  color: #4CAF50;
}
.status-closed {
  background: #F5F5F5;
  color: #999;
}

.card-body {
  display: flex;
  padding: 24rpx;
}
.room-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.room-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
}
.date, .remark {
  font-size: 24rpx;
  color: #888;
}
.price {
  font-size: 28rpx;
  font-weight: bold;
  color: #FE6A3D;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #F4F4F4;
}
.time {
  font-size: 22rpx;
  color: #bbb;
}
.pay-btn {
  background: #FE6A3D;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  border: none;
}
