.contain {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}
.info {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}
.form-item {
  margin-bottom: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}
.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}
.input {
  font-size: 32rpx;
  color: #333;
  padding: 10rpx 0;
  width: 100%;
}
.picker-text {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx 0;
}
.textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #333;
  padding: 10rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}
.submit-btn {
  margin-top: 50rpx;
  background: #87CEFB;
  color: #fff;
  font-size: 32rpx;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
}
.submit-btn[disabled] {
  opacity: 0.6;
}
