.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 30rpx;
}
.header {
  margin-bottom: 30rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
.faq-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.faq-item {
  border-bottom: 2rpx solid #f0f0f0;
}
.faq-item:last-child {
  border-bottom: none;
}
.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}
.q-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}
.q-arrow {
  font-size: 40rpx;
  color: #ccc;
  transition: transform 0.3s;
  margin-left: 20rpx;
}
.q-arrow.active {
  transform: rotate(90deg);
}
.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  padding: 0 30rpx;
}
.faq-answer.show {
  max-height: 400rpx;
  padding: 0 30rpx 30rpx;
}
.a-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}
