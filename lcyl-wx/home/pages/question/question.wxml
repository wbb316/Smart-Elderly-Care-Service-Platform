<view class="page">
  <view class="header">
    <text class="title">常见问题</text>
  </view>

  <view class="faq-list">
    <view class="faq-item" wx:for="{{faqList}}" wx:key="index">
      <view class="faq-question" bindtap="toggleAnswer" data-index="{{index}}">
        <text class="q-text">{{item.q}}</text>
        <text class="q-arrow {{item.open ? 'active' : ''}}">›</text>
      </view>
      <view class="faq-answer {{item.open ? 'show' : ''}}">
        <text class="a-text">{{item.a}}</text>
      </view>
    </view>
  </view>
</view>
