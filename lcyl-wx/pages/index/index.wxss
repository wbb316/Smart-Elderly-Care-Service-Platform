.page-container {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
}

.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.content {
  position: relative;
  z-index: 1;
  min-height: 100vh;
}

.log_btn {
  position: fixed;
  bottom: 100rpx;
  left: 0;
  right: 0;
  padding: 0 40rpx;
}

.log_btn button {
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  padding-top: 20rpx;
  height: 88rpx;
  /* line-height: 88rpx; */
  font-size: 32rpx;
}