page {
  background: #f6f6f6;
}

.mine-page {
  min-height: 100vh;
  background: #f6f6f6;
}

/* 顶部背景区域 */
.top-banner {
  height: 420rpx;
  position: relative;
  overflow: hidden;
  padding: 140rpx 40rpx 0;
  box-sizing: border-box;
}

/* 顶部背景图：用 image 代替 background-image */
.banner-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 用户信息盖在背景图上 */
.user-info {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
  margin-right: 24rpx;
  background: #ffffff;
}

.username {
  font-size: 44rpx;
  color: #ffffff;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

/* 内容整体上移 */
.content-wrap {
  margin-top: -40rpx;
  padding: 0 30rpx 40rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 3;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 26rpx;
}

.section-header {
  height: 104rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 40rpx;
  color: #222222;
  font-weight: 700;
}

.more-wrap {
  display: flex;
  align-items: center;
}

.section-more {
  font-size: 30rpx;
  color: #999999;
}

.more-arrow {
  font-size: 38rpx;
  color: #999999;
  margin-left: 8rpx;
  line-height: 1;
}

.order-card {
  padding-bottom: 18rpx;
}

.order-tabs {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 12rpx 30rpx;
}

.order-nav {
  flex: 1;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.order-pic {
  width: 42rpx;
  height: 42rpx;
}

.tab-text {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.4;
}

.menu-card {
  padding: 0;
}

.menu-item {
  height: 108rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
}

.no-border {
  border-bottom: none;
}

.menu-text {
  font-size: 36rpx;
  color: #222222;
  font-weight: 500;
}

.menu-arrow {
  font-size: 44rpx;
  color: #222222;
  line-height: 1;
}

.logout-wrap {
  margin-top: 60rpx;
  padding: 0 2rpx;
}

.logout-btn {
  height: 92rpx;
  background: #ffffff;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.03);
}

.logout-text {
  font-size: 36rpx;
  color: #222222;
  font-weight: 500;
  background-color: white;
}